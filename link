#!/usr/bin/env bash
# link - Fallback symlink generator for systems without GNU Stow

# 🚨 FORCE GIT BASH TO USE REAL NTFS SYMLINKS ON WINDOWS
# export MSYS="winsymlinks:nativestrict"

echo "========================================"
echo "🔗 Starting Manual Symlink Fallback"
echo "========================================"

DOTFILES_DIR="$HOME/.dotfiles"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)

# Helper function to create links securely
link_file() {
  local src="$1"
  local dest="$2"

  # Ensure destination directory exists
  mkdir -p "$(dirname "$dest")"

  # Back up existing file/folder if it exists and is NOT a symlink
  if [ -e "$dest" ] && [ ! -L "$dest" ]; then
    echo "  📦 Backing up existing $dest to ${dest}.${TIMESTAMP}.bak"
    mv "$dest" "${dest}.${TIMESTAMP}.bak"
  fi

  # Create or update the symlink
  echo "  🔗 Linking $(basename "$dest") -> $src"
  # We use rm -f first because nativestrict will fail if a fake symlink copy already exists
  rm -f "$dest" 2>/dev/null
  ln -s "$src" "$dest"
}

echo "💻 Linking Core Configs..."

# 1. Bash
link_file "$DOTFILES_DIR/bash/.bashrc" "$HOME/.bashrc"
link_file "$DOTFILES_DIR/bash/.bash_aliases" "$HOME/.bash_aliases"
link_file "$DOTFILES_DIR/bash/.profile" "$HOME/.profile"

# 2. Git & SSH
link_file "$DOTFILES_DIR/git/.gitconfig" "$HOME/.gitconfig"
if [ -f "$DOTFILES_DIR/git/.ssh/config" ]; then
  link_file "$DOTFILES_DIR/git/.ssh/config" "$HOME/.ssh/config"
  chmod 700 "$HOME/.ssh"
  chmod 600 "$HOME/.ssh/config"
fi

# 3. Neovim
link_file "$DOTFILES_DIR/nvim/.config/nvim" "$HOME/.config/nvim"

# 4. Tmux
link_file "$DOTFILES_DIR/tmux/.tmux.conf" "$HOME/.tmux.conf"

# 5. Starship
link_file "$DOTFILES_DIR/starship/.config/starship.toml" "$HOME/.config/starship.toml"

# 6. Fastfetch
link_file "$DOTFILES_DIR/fastfetch/.config/fastfetch" "$HOME/.config/fastfetch"

# 7. Scripts
link_file "$DOTFILES_DIR/scripts/scripts" "$HOME/scripts"

# 8. Mise
link_file "$DOTFILES_DIR/mise/.config/mise" "$HOME/.config/mise"

# 8. Windows Terminal (OS-Aware Copy, NOT Symlink)
if [[ "$OSTYPE" == "msys" || "$OSTYPE" == "cygwin" ]]; then
  echo "🪟 Windows detected. Copying Windows Terminal settings..."
  WT_DEST="$HOME/AppData/Local/Packages/Microsoft.WindowsTerminal_8wekyb3d8bbwe/LocalState/settings.json"

  if [ -f "$WT_DEST" ]; then
    echo "  📦 Backing up Windows Terminal config..."
    cp "$WT_DEST" "${WT_DEST}.${TIMESTAMP}.bak"
  fi

  # NOTE: We MUST copy this, not link it. UWP apps like Windows Terminal
  # often break or delete symlinks when they auto-save their own settings.
  echo "  📝 Copying settings.json to LocalState"
  cp "$DOTFILES_DIR/windows-terminal/settings.json" "$WT_DEST"
fi

echo "========================================"
echo "✅ Manual linking complete!"
echo "========================================"
