# ==========================================
# ~/.gitconfig (Master Dotfiles)
# ==========================================

[user]
    name = Aman Kumar Gupta
    email = 97891757+Aman1337g@users.noreply.github.com

[credential]
    # helper = store
    # Use GCM for Windows if available, else keep 'store'
    # helper = /mnt/c/Program\ Files/Git/mingw64/bin/git-credential-manager.exe
    # echo -e "protocol=https\nhost=github.com" | git credential fill
    helper = "!$HOME/scripts/git-credential-universal"

[init]
    defaultBranch = main

# --- UI & Pagers (Combined from WSL & Dotfiles) ---
[core]
    autocrlf = input
    pager = delta
    filemode = false

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true

# --- Diff Tools ---
[diff]
    tool = kitty
    guitool = kitty.gui

[difftool]
    prompt = false
    trustExitCode = true

[difftool "kitty"]
    cmd = kitten diff $LOCAL $REMOTE

[difftool "kitty.gui"]
    cmd = kitten diff $LOCAL $REMOTE

# --- LFS (From Windows) ---
[filter "lfs"]
    process = git-lfs filter-process
    required = true
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f

# --- Safe Directories (For WSL/Windows interop) ---
[safe]
    directory = *

# ==========================================
# 🛑 The Magic Switch for Work Repos
# ==========================================

# 1. Matches if the .git folder is anywhere inside /mnt/c/Users/
[includeIf "gitdir/i:/mnt/c/Users/"]
    path = ~/.gitconfig-work

# 2. Catch the exact same folder when you are using Windows Git Bash
[includeIf "gitdir/i:C:/Users/"]
    path = ~/.gitconfig-work



