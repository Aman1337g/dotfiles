# ==========================================
# ~/.gitconfig (Master Dotfiles)
# ==========================================

[user]
    name = Aman Kumar Gupta
    email = 97891757+Aman1337g@users.noreply.github.com

[init]
    defaultBranch = main

# --- UI & Pagers (Combined from WSL & Dotfiles) ---
[core]
    autocrlf = input
    pager = delta
    filemode = false

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true

# --- Diff Tools ---
[diff]
    tool = kitty
    guitool = kitty.gui

[difftool]
    prompt = false
    trustExitCode = true

[difftool "kitty"]
    cmd = kitten diff $LOCAL $REMOTE

[difftool "kitty.gui"]
    cmd = kitten diff $LOCAL $REMOTE

# --- LFS (From Windows) ---
[filter "lfs"]
    process = git-lfs filter-process
    required = true
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f

# --- Safe Directories (For WSL/Windows interop) ---
[safe]
    directory = *

# ==========================================
# 🛑 The Magic Switch for Work Repos
# ==========================================

# 1. Catch the folder when you are using WSL
[includeIf "gitdir:/mnt/c/Users/"]
    path = ~/.gitconfig-work

# 2. Catch the exact same folder when you are using Windows Git Bash
[includeIf "gitdir:C:/Users/"]
    path = ~/.gitconfig-work



