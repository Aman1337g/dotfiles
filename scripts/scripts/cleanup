#!/usr/bin/env bash
# cleanup.sh - Universal System Cleanup

# Colors for output
YELLOW='\033[1;33m'
GREEN='\033[1;32m'
RED='\033[0;31m'
RC='\033[0m'

echo "========================================"
printf "%b\n" "${YELLOW}🧹 Starting Universal System Cleanup...${RC}"
echo "========================================"

_has() { command -v "$1" >/dev/null 2>&1; }

# --- 1. OS-Specific Package Cleanup ---
printf "%b\n" "${YELLOW}📦 Performing package cache cleanup...${RC}"

if [ -n "$TERMUX_VERSION" ]; then
  echo "📱 Cleaning Termux packages..."
  pkg clean

elif _has brew; then
  echo "🍏 Cleaning Homebrew packages..."
  brew cleanup

elif _has apt; then
  echo "🐧 Cleaning apt packages..."
  sudo apt autoremove -y
  sudo apt autoclean
  sudo apt clean

elif _has apk; then
  echo "🏔️ Cleaning apk cache..."
  sudo rm -rf /var/cache/apk/*

elif [[ "$OSTYPE" == "msys" || "$OSTYPE" == "cygwin" ]]; then
  echo "🪟 Windows detected. (Winget manages its own cache automatically)."
fi

# --- 2. Common Temporary Files & Logs ---
printf "%b\n" "${YELLOW}🗑️ Cleaning temporary files and logs...${RC}"

# Safely clean temp directories using mtime (modification time)
if [ -n "$TERMUX_VERSION" ]; then
    # Termux uses a specific temp directory
    find "$PREFIX/tmp" -type f -mtime +5 -delete 2>/dev/null || true
else
    if _has sudo; then
        [ -d /var/tmp ] && sudo find /var/tmp -type f -mtime +5 -delete 2>/dev/null || true
        [ -d /tmp ] && sudo find /tmp -type f -mtime +5 -delete 2>/dev/null || true
        
        # Safely vacuum systemd logs (much safer than truncating raw .log files!)
        if _has journalctl; then
            sudo journalctl --vacuum-time=3d 2>/dev/null || true
        fi
    fi
fi

# --- 3. User Data (Cache, Trash, and DevOps Tools) ---
printf "%b" "${YELLOW}⚠️ Clean up old user cache and empty the trash? (y/N): ${RC}"
read -r clean_response
case "$clean_response" in
  [yY]* )
    printf "%b\n" "${YELLOW}🧹 Cleaning user cache and trash...${RC}"
    
    # Clean cache older than 7 days
    if [ -d "$HOME/.cache" ]; then
        find "$HOME/.cache/" -type f -mtime +7 -delete 2>/dev/null || true
    fi
    
    # Empty Trash safely
    if [ -d "$HOME/.local/share/Trash" ]; then
        rm -rf "$HOME/.local/share/Trash/"* 2>/dev/null || true
    fi
    
    # 🐳 DevOps Bonus: Clean old Docker images/volumes
    if _has docker; then
        echo "🐳 Cleaning up unused Docker assets..."
        docker system prune -af --volumes >/dev/null 2>&1 || true
    fi
    
    printf "%b\n" "${GREEN}✅ User data cleanup completed.${RC}"
    ;;
  * )
    printf "%b\n" "${YELLOW}⏭️ Skipping user cache and trash cleanup.${RC}"
    ;;
esac

echo "========================================"
printf "%b\n" "${GREEN}✨ System is now lean and mean!${RC}"
echo "========================================"
