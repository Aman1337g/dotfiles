#!/usr/bin/env bash
# ~/.dotfiles/scripts/scripts/git-credential-universal
# Routes Git credential requests to the fastest suitable OS-native helper

# ==========================================
# ⚙️ CONFIGURATION
# ==========================================
# For Linux/Termux/Containers:
# Set to "store" -> Permanent plaintext file (Convenient, but less secure)
# Set to "cache" -> 2-hour in-memory cache (Highly secure, requires re-entry)
LINUX_AUTH_MODE="store"

# ==========================================
# 🚀 ROUTING LOGIC
# ==========================================
OS="$(uname -s)"

run_gcm() {
    local candidate

    for candidate in \
        git-credential-manager.exe \
        /mnt/c/Program\ Files/Git/mingw64/bin/git-credential-manager.exe \
        /mnt/c/Program\ Files/Git/mingw64/libexec/git-core/git-credential-manager.exe \
        /c/Program\ Files/Git/mingw64/bin/git-credential-manager.exe \
        /c/Program\ Files/Git/mingw64/libexec/git-core/git-credential-manager.exe
    do
        if command -v "$candidate" >/dev/null 2>&1; then
            exec "$candidate" "$@"
        fi

        if [ -f "$candidate" ]; then
            exec "$candidate" "$@"
        fi
    done

    if git help -a 2>/dev/null | grep -q '^  credential-manager$'; then
        exec git credential-manager "$@"
    fi

    echo "Error: Git Credential Manager not found in PATH or common install locations" >&2
    exit 1
}

# 1. macOS (Native Apple Keychain)
if [[ "$OS" == "Darwin" ]]; then
    exec git credential-osxkeychain "$@"

# 2. WSL (Windows Credential Manager)
elif grep -qi microsoft /proc/version 2>/dev/null; then
    run_gcm "$@"

# 3. Native Windows shells using Git Bash / MSYS / Cygwin
elif [[ "$OS" =~ ^(MINGW|MSYS|CYGWIN) ]]; then
    run_gcm "$@"

# 4. Termux / Headless Linux / Containers
else
    if [[ "$LINUX_AUTH_MODE" == "store" ]]; then
        # Permanent storage (Saves to ~/.git-credentials)
        exec git credential-store "$@"
    else
        # In-memory storage (Disappears after 2 hours of inactivity)
        exec git credential-cache --timeout=7200 "$@"
    fi
fi
