#!/usr/bin/env bash
# ~/.dotfiles/scripts/scripts/git-credential-universal
# Routes Git credential requests to the fastest suitable OS-native helper
# Works on: macOS, Linux, WSL, Git Bash, MSYS, Cygwin, Termux, Containers, Alpine, Arch, etc.
# To erase stored credentials: printf 'protocol=https\nhost=github.com\n\n' | git credential reject

# ==========================================
# ⚙️ CONFIGURATION
# ==========================================
# For Linux/WSL/Containers (in order of preference):
#   "libsecret" → Encrypted via GNOME Keyring / KWallet (most secure, never re-prompts)
#                 Setup (one-time, dev deps can be removed after):
#                   sudo apt install libsecret-1-0 libsecret-1-dev build-essential
#                   sudo make --directory=/usr/share/doc/git/contrib/credential/libsecret
#                   sudo ln -sf /usr/share/doc/git/contrib/credential/libsecret/git-credential-libsecret /usr/local/bin/
#                   sudo apt remove --autoremove libsecret-1-dev build-essential
#                 No recompile needed for libsecret-1-0 updates (ABI-stable while soname stays libsecret-1.so.0)
#   "store"     → Permanent plaintext file (~/.git-credentials). Never re-prompts, but readable on disk.
#   "cache"     → In-memory only. Re-prompts after timeout. Most secure, least convenient.
LINUX_AUTH_MODE="libsecret"

# ==========================================
# 🚀 HELPER FUNCTIONS
# ==========================================
OS="$(uname -s)"

try_gcm() {
    # Git Credential Manager — encrypted persistent storage via OS Credential Manager.
    # Ideal for Windows (Git Bash) and native Linux GCM installs.
    local candidates=(
        "git-credential-manager"
        "git-credential-manager.exe"
        "/mnt/c/Program Files/Git/mingw64/bin/git-credential-manager.exe"
        "/c/Program Files/Git/mingw64/bin/git-credential-manager.exe"
    )
    local c
    for c in "${candidates[@]}"; do
        if command -v "$c" >/dev/null 2>&1 || [ -x "$c" ]; then
            exec "$c" "$@"
        fi
    done
    return 1
}

try_libsecret() {
    # Linux secure storage via GNOME Keyring / KWallet.
    # Credentials are encrypted on disk; unlocked on login. Never re-prompts.
    # Guard: requires a running D-Bus session with a registered secrets service.
    # Without it (headless/WSL without desktop), fall through to next helper.
    if [ -z "$DBUS_SESSION_BUS_ADDRESS" ]; then
        return 1
    fi
    if ! dbus-send --session --print-reply --dest=org.freedesktop.DBus \
        /org/freedesktop/DBus org.freedesktop.DBus.ListNames 2>/dev/null \
        | grep -q 'org.freedesktop.secrets'; then
        return 1
    fi
    if git help -a 2>/dev/null | grep -q 'credential-libsecret'; then
        exec git credential-libsecret "$@"
    fi
    return 1
}

try_osxkeychain() {
    # macOS encrypted Keychain.
    if command -v git-credential-osxkeychain >/dev/null 2>&1; then
        exec git-credential-osxkeychain "$@"
    fi
    return 1
}

try_store() {
    # Permanent plaintext storage (~/.git-credentials). Credentials never expire.
    # Less secure: readable by anyone with filesystem access.
    if command -v git-credential-store >/dev/null 2>&1; then
        exec git-credential-store "$@"
    fi
    return 1
}

try_cache() {
    # In-memory only; re-prompts after timeout. Safest but least convenient.
    if command -v git-credential-cache >/dev/null 2>&1; then
        exec git-credential-cache --timeout=7200 "$@"
    fi
    return 1
}

# ==========================================
# 🛣️ MAIN ROUTING LOGIC
# ==========================================

# 1. macOS → Keychain (encrypted) → GCM → store → cache
if [[ "$OS" == "Darwin" ]]; then
    try_osxkeychain "$@" || try_gcm "$@" || try_store "$@" || try_cache "$@"

# 2. Windows Git Bash / MSYS / Cygwin → GCM (Windows Credential Manager) → store → cache
elif [[ "$OS" =~ ^(MINGW|MSYS|CYGWIN) ]]; then
    try_gcm "$@" || try_store "$@" || try_cache "$@"

# 3. WSL → libsecret (encrypted) → GCM → store → cache
elif grep -qi microsoft /proc/version 2>/dev/null; then
    if [[ "$LINUX_AUTH_MODE" == "libsecret" ]]; then
        try_libsecret "$@" || try_gcm "$@" || try_store "$@" || try_cache "$@"
    else
        try_store "$@" || try_cache "$@"
    fi

# 4. Linux / Containers / Alpine / Arch / Termux → libsecret → GCM → store → cache
else
    if [[ "$LINUX_AUTH_MODE" == "libsecret" ]]; then
        try_libsecret "$@" || try_gcm "$@" || try_store "$@" || try_cache "$@"
    else
        try_store "$@" || try_cache "$@"
    fi
fi

echo "Error: No Git credential helper available on this system" >&2
exit 1
