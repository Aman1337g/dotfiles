#!/usr/bin/env bash
# ~/scripts/git-credential-universal
# Routes Git credential requests to the correct OS-native helper

# ==========================================
# ⚙️ CONFIGURATION
# ==========================================
# For Linux/Termux/Containers:
# Set to "store" -> Permanent plaintext file (Convenient, but less secure)
# Set to "cache" -> 2-hour in-memory cache (Highly secure, requires re-entry)
LINUX_AUTH_MODE="store"

# ==========================================
# 🚀 ROUTING LOGIC
# ==========================================
OS="$(uname -s)"

# 1. macOS (Native Apple Keychain)
if [[ "$OS" == "Darwin" ]]; then
    exec git credential-osxkeychain "$@"

# 2. WSL (Windows Credential Manager)
elif grep -qi microsoft /proc/version 2>/dev/null; then
    # Define the path securely in a variable to protect the space
    GCM_PATH="/mnt/c/Program Files/Git/mingw64/bin/git-credential-manager.exe"
    
    if [ -f "$GCM_PATH" ]; then
        exec "$GCM_PATH" "$@"
    else
        echo "Error: Windows Git Credential Manager not found at $GCM_PATH" >&2
        exit 1
    fi

# 3. Termux / Headless Linux / Containers
else
    if [[ "$LINUX_AUTH_MODE" == "store" ]]; then
        # Permanent storage (Saves to ~/.git-credentials)
        exec git credential-store "$@"
    else
        # In-memory storage (Disappears after 2 hours of inactivity)
        exec git credential-cache --timeout=7200 "$@"
    fi
fi
