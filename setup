#!/usr/bin/env bash
# Aman's Ultimate Environment Bootstrapper

echo "========================================"
echo "🚀 Starting System Bootstrap..."
echo "========================================"

# --- 📱 Termux Pre-Flight Check ---
if [ -n "$TERMUX_VERSION" ]; then
  if ! command -v git >/dev/null 2>&1; then
    echo "📱 Termux detected without Git. Installing prerequisite..."
    pkg update -y && pkg install git -y
  fi
fi

DOTFILES_DIR="$HOME/.dotfiles"

# 1. Clone the repository if it doesn't exist
if [ ! -d "$DOTFILES_DIR" ]; then
  echo "📦 Cloning dotfiles repository..."
  git clone https://github.com/Aman1337g/dotfiles.git "$DOTFILES_DIR"
else
  echo "✅ Dotfiles repository already exists at $DOTFILES_DIR"
fi

cd "$DOTFILES_DIR" || exit 1

# 2. Run the universal installer
echo ""
echo "🛠️  Running Universal Tool Installer..."
chmod +x install_tools link setup
./install_tools

# 3. Apply configurations based on the environment
echo ""
echo "========================================"
echo "🔗 Linking Dotfiles Configuration"
echo "========================================"

if command -v stow >/dev/null 2>&1; then
  echo "✅ GNU Stow detected. Proceeding with modular links..."

  echo "  -> 🧹 Clearing runway for Stow (Handling old symlinks and defaults)..."
  # We remove old symlinks or backup physical files to give Stow a blank canvas
  for target in ~/.bashrc ~/.bash_aliases ~/.profile ~/.gitconfig ~/.tmux.conf ~/.ssh/config ~/.config/nvim ~/.config/starship.toml ~/.config/fastfetch ~/scripts; do
    if [ -L "$target" ]; then
      rm "$target" # Remove conflicting symlinks from link.sh
    elif [ -f "$target" ]; then
      mv "$target" "${target}.bak" # Backup factory defaults
    fi
  done

  echo "  -> 💻 Stowing Core CLI Tools..."
  echo "     (bash, scripts, git, nvim, tmux, starship, fastfetch)"
  # Using explicit paths prevents the Stow Perl bug!
  stow --dir="$DOTFILES_DIR" --target="$HOME" bash scripts git nvim tmux starship fastfetch

  # Smart detection: Only stow GUI apps if a display server is running
  if [ -n "${WAYLAND_DISPLAY:-}" ] || [ -n "${DISPLAY:-}" ]; then
    echo "  -> 🖥️  GUI Environment detected! Stowing Desktop Apps..."
    stow --dir="$DOTFILES_DIR" --target="$HOME" code kitty fonts sway yazi zathura qutebrowser

    if [ -f "scripts/scripts/install_themes.sh" ]; then
      chmod +x scripts/scripts/install_themes.sh
      ./scripts/scripts/install_themes.sh
    fi
  else
    echo "  -> 🖥️  No GUI detected (Headless/WSL/Termux). Skipping desktop apps."
  fi

  echo "  -> ⚠️  Note: System-level configs (etc-*) skipped in automated run."
  echo "     Run 'sudo stow --target=/etc etc-copy-paste-hang-sol' manually if required."

else
  echo "🪟 GNU Stow not found (likely Windows Git Bash)."
  echo "  -> Falling back to link script for core configs..."
  ./link
fi

echo "========================================"
echo "✨ Bootstrap Complete! Restart your terminal to see the magic."
echo "========================================"
