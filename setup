#!/usr/bin/env bash
# Aman's Ultimate Environment Bootstrapper (Interactive & Automatable)

# ==========================================
# ⚙️ 1. ARGUMENT PARSING & FLAGS
# ==========================================
AUTO_MODE=false
ENV_TYPE=""
INSTALL_GUI=false

while [[ "$#" -gt 0 ]]; do
  case $1 in
  --auto) AUTO_MODE=true ;;
  --gui) INSTALL_GUI=true ;;
  --env=*) ENV_TYPE="${1#*=}" ;;
  *)
    echo "Unknown parameter passed: $1"
    exit 1
    ;;
  esac
  shift
done

# ==========================================
# 🧠 SMART AUTO-DETECTION & TTY CHECK
# ==========================================
DEFAULT_ENV="linux"
if [ -n "$TERMUX_VERSION" ]; then
  DEFAULT_ENV="termux"
elif [ -f /.dockerenv ] || [ -f /run/.containerenv ]; then
  DEFAULT_ENV="container"
elif grep -qi microsoft /proc/version 2>/dev/null; then
  DEFAULT_ENV="wsl"
elif [[ "$OSTYPE" == "darwin"* ]]; then
  DEFAULT_ENV="mac"
elif [[ "$OSTYPE" == "msys" || "$OSTYPE" == "cygwin" ]]; then
  DEFAULT_ENV="windows"
fi

# If stdin is not a terminal (e.g., curl | bash), force AUTO_MODE
if [ ! -t 0 ]; then
  echo "⚠️ Piped execution detected. Forcing Auto Mode."
  AUTO_MODE=true
fi

export ENV_TYPE

# ==========================================
# 🗣️ 2. INTERACTIVE MENU (If not in --auto mode)
# ==========================================
if [ "$AUTO_MODE" = false ]; then
  echo ""
  echo "🤖 Welcome to the Environment Setup."

  if [ -z "$ENV_TYPE" ]; then
    echo "Select your target environment:"
    echo "  1) Linux (Native/Debian/Arch)"
    echo "  2) WSL (Windows Subsystem for Linux)"
    echo "  3) macOS"
    echo "  4) DevPod / Container (Ephemeral)"
    echo "  5) Windows Git Bash"
    # Force read from tty just in case
    read -p "Enter choice [1-5] (Default: $DEFAULT_ENV): " env_choice </dev/tty
    case $env_choice in
    1) ENV_TYPE="linux" ;;
    2) ENV_TYPE="wsl" ;;
    3) ENV_TYPE="mac" ;;
    4) ENV_TYPE="container" ;;
    5) ENV_TYPE="windows" ;;
    *) ENV_TYPE="$DEFAULT_ENV" ;;
    esac
  fi

  if [[ "$ENV_TYPE" =~ (linux|mac) ]]; then
    read -p "🖥️  Install GUI Desktop Apps (Kitty, Zathura, etc.)? (y/n): " gui_choice </dev/tty
    if [[ "$gui_choice" =~ ^[Yy]$ ]]; then
      INSTALL_GUI=true
    fi
  fi
else
  # In AUTO_MODE, if ENV_TYPE wasn't explicitly passed via flag, use the auto-detected one
  if [ -z "$ENV_TYPE" ]; then
    ENV_TYPE="$DEFAULT_ENV"
    echo "🤖 Auto-detected environment: $ENV_TYPE"
  fi
fi

export ENV_TYPE
export INSTALL_GUI
export AUTO_MODE

echo "========================================"
echo "🚀 Starting System Bootstrap..."
echo "========================================"

# --- 📱 Termux Pre-Flight Check ---
if [ -n "$TERMUX_VERSION" ]; then
  ENV_TYPE="termux"
  if ! command -v git >/dev/null 2>&1; then
    echo "📱 Termux detected without Git. Installing prerequisite..."
    pkg update -y && pkg install git -y
  fi
fi

DOTFILES_DIR="$HOME/.dotfiles"

# ==========================================
# 📦 3. CLONE DOTFILES
# ==========================================
if [ ! -d "$DOTFILES_DIR" ]; then
  echo "📦 Cloning dotfiles repository..."
  git clone https://github.com/Aman1337g/dotfiles.git "$DOTFILES_DIR"
else
  echo "✅ Dotfiles repository already exists at $DOTFILES_DIR"
fi

cd "$DOTFILES_DIR" || exit 1
chmod +x install_tools link setup

# ==========================================
# 🔗 4. LINKING (Done BEFORE installing tools so Mise has its config)
# ==========================================
echo ""
echo "========================================"
echo "🔗 Linking Dotfiles Configuration"
echo "========================================"

# Ensure stow is installed before trying to use it if on a brand new container
if ! command -v stow >/dev/null 2>&1; then
  echo "⚠️ GNU Stow not found. We will install it during the tool phase."
  echo "Falling back to safe link script for initial bootstrap..."
  ./link
else
  echo "✅ GNU Stow detected. Proceeding with modular links..."
  echo "  -> 🧹 Clearing runway for Stow (Handling old symlinks and defaults)..."

  # 1. Expanded list of ALL targets (CLI + GUI)
  STOW_TARGETS=(
    ~/.bashrc ~/.bash_aliases ~/.profile ~/.gitconfig ~/.tmux.conf ~/.ssh/config
    ~/.config/nvim ~/.config/starship.toml ~/.config/fastfetch ~/scripts ~/.config/mise
    ~/.config/qutebrowser ~/.config/kitty ~/.config/sway ~/.config/yazi ~/.config/zathura
  )

  TIMESTAMP=$(date +%Y%m%d_%H%M%S)

  for target in "${STOW_TARGETS[@]}"; do
    if [ -L "$target" ]; then
      rm "$target" # Safely remove old symlinks
    elif [ -f "$target" ] || [ -d "$target" ]; then
      echo "  📦 Backing up $target to ${target}_${TIMESTAMP}.bak"
      mv "$target" "${target}_${TIMESTAMP}.bak"
    fi
  done

  echo "  -> 💻 Stowing Core CLI Tools..."
  stow --dir="$DOTFILES_DIR" --target="$HOME" bash scripts git nvim tmux starship fastfetch mise

  # Stow GUI only if requested
  if [ "$INSTALL_GUI" = true ] || [ -n "${WAYLAND_DISPLAY:-}" ] || [ -n "${DISPLAY:-}" ]; then
    echo "  -> 🖥️  GUI Environment detected! Stowing Desktop Apps..."
    stow --dir="$DOTFILES_DIR" --target="$HOME" code kitty fonts sway yazi zathura qutebrowser

    if [ -f "scripts/scripts/install_themes" ]; then
      chmod +x scripts/scripts/install_themes
      ./scripts/scripts/install_themes
    fi
  fi
fi

# ==========================================
# 🛠️ 5. UNIVERSAL TOOL INSTALLER (Mise First)
# ==========================================
echo ""
echo "========================================"
echo "🛠️  Running Universal Tool Installer..."
echo "========================================"

# Pass the flags down to the install script
INSTALL_ARGS=("--env=$ENV_TYPE")
if [ "$INSTALL_GUI" = true ]; then INSTALL_ARGS+=("--gui"); fi
if [ "$AUTO_MODE" = true ]; then INSTALL_ARGS+=("--auto"); fi

./install_tools "${INSTALL_ARGS[@]}"

echo "========================================"
echo "✨ Bootstrap Complete! Restart your terminal to see the magic."
echo "========================================"
