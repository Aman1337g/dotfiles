#!/usr/bin/env bash
# install_tools - Universal Environment Bootstrapper (Mise-First Architecture)

echo "========================================"
echo "🚀 Starting System Dependencies & Mise Engine..."
echo "========================================"

# --- Argument Parsing ---
ENV_TYPE=""
INSTALL_GUI=false

while [[ "$#" -gt 0 ]]; do
  case $1 in
  --env=*) ENV_TYPE="${1#*=}" ;;
  --gui) INSTALL_GUI=true ;;
  esac
  shift
done

# ---------------------------------------------------------
# 📝 SYSTEM BASE PACKAGES (LIFELINES ONLY)
# All user tools (Neovim, Eza, Starship, etc.) are managed
# by ~/.config/mise/config.toml at the end of the script.
# ---------------------------------------------------------
BREW_BASE=(git curl unzip stow)
APT_BASE=(git curl unzip stow build-essential ca-certificates jq)
APK_BASE=(git curl unzip stow build-base jq)
TERMUX_BASE=(git curl wget jq tmux openssh stow)
WINDOWS_BASE=(dandavison.delta) # Winget packages if needed before mise

# GUI Packages (Installed only if --gui is passed)
APT_GUI=(kitty zathura qutebrowser)

_has() { command -v "$1" >/dev/null 2>&1; }

# ==========================================
# ⚙️ 1. OS-LEVEL PREREQUISITES
# ==========================================

# --- Pull corporate certs before downloading anything else ---
if command -v powershell.exe >/dev/null 2>&1; then
  # Point directly to the source of truth in the dotfiles repo just in case stow hasn't run
  CERT_SCRIPT="$HOME/.dotfiles/scripts/scripts/sync_certs"
  if [ -f "$CERT_SCRIPT" ]; then
    echo "🔄 Running Zscaler Certificate Sync..."
    bash "$CERT_SCRIPT"
  fi
fi

# --- 0. Android (Termux) ---
if [ "$ENV_TYPE" = "termux" ] || [ -n "$TERMUX_VERSION" ]; then
  echo "📱 Termux detected. Installing system base..."
  pkg update -y
  pkg install -y "${TERMUX_BASE[@]}"

  # Termux fallback: If mise struggles with ARM Android, install core natively
  if ! _has eza; then
    pkg install -y eza bat fzf zoxide starship neovim
  fi

# --- 1. macOS (Homebrew) ---
elif _has brew || [ "$ENV_TYPE" = "mac" ]; then
  echo "🍏 macOS detected. Installing system base via Homebrew..."
  brew install "${BREW_BASE[@]}"

# --- 2. Debian / Ubuntu / WSL / Container ---
elif _has apt || [[ "$ENV_TYPE" =~ (linux|wsl|container) ]]; then
  echo "🐧 Debian-based system detected. Installing lifelines via apt..."
  sudo apt-get update -y
  sudo apt-get install -y "${APT_BASE[@]}"

  # Ubuntu calls bat 'batcat', fix for system scripts that expect 'bat'
  mkdir -p ~/.local/bin
  [ -f /usr/bin/batcat ] && ln -sf /usr/bin/batcat ~/.local/bin/bat

  # --- Native GUI Applications ---
  if [ "$INSTALL_GUI" = true ]; then
    echo "🖥️  Installing Native GUI Applications..."
    sudo apt-get install -y "${APT_GUI[@]}"
  fi

  # --- 🐳 Docker Native Engine (Skip in Containers/WSL) ---
  if [ "$ENV_TYPE" != "container" ] && [ "$ENV_TYPE" != "wsl" ] && ! _has docker; then
    echo "🐳 Installing native Docker Engine..."
    curl -k -fsSL https://get.docker.com -o get-docker.sh
    # 🚨 Hack: permanently remove the 20-second sleep penalty
    sed -i 's/sleep 20/sleep 0/' get-docker.sh
    sudo sh get-docker.sh && rm get-docker.sh
    sudo usermod -aG docker "$USER"
    echo "⚠️ Docker installed. (Log out and back in for group permissions to apply)."
  fi

  # --- 🚀 DevPod CLI ---
  if ! _has devpod; then
    echo "🚀 Installing DevPod CLI..."
    curl -k -L -o devpod "https://github.com/loft-sh/devpod/releases/latest/download/devpod-linux-amd64"
    sudo install -c -m 0755 devpod /usr/local/bin
    rm devpod
  fi

# --- 3. Alpine Linux ---
elif _has apk; then
  echo "🏔️ Alpine detected. Using apk..."
  sudo apk add "${APK_BASE[@]}"

# --- 4. Windows Git Bash ---
elif [[ "$OSTYPE" == "msys" || "$OSTYPE" == "cygwin" ]] || [ "$ENV_TYPE" = "windows" ]; then
  echo "🪟 Windows Git Bash detected. Bypassing UAC..."
  mkdir -p ~/.local/bin

  if _has winget; then
    for pkg in "${WINDOWS_BASE[@]}"; do
      winget install --id="$pkg" --scope user --accept-package-agreements --accept-source-agreements || true
    done
  fi

  # Ensure local bin is ready for portable binaries
  if [ -d "$HOME/.local/bin" ]; then
    chmod +x "$HOME/.local/bin"/* 2>/dev/null || true
  fi
fi

# ==========================================
# 🧰 2. THE MISE POLYGLOT ENGINE
# ==========================================
echo ""
echo "========================================"
echo "🧰 Activating Mise-First Environment"
echo "========================================"

# Bypass corporate SSL inspection universally for this session
export MISE_INSECURE_HTTPS=1
echo "insecure" >~/.curlrc

# --- Install Mise CLI ---
if ! _has mise; then
  echo "⬇️ Downloading Mise..."

  if [[ "$OSTYPE" == "msys" || "$OSTYPE" == "cygwin" ]] || [ "$ENV_TYPE" = "windows" ]; then
    # Windows Portable Mise
    mkdir -p ~/.local/bin
    curl -k -sLo ~/.local/bin/mise.exe "https://github.com/jdx/mise/releases/latest/download/mise-v2024.1.1-windows-x64.exe"
    chmod +x ~/.local/bin/mise.exe
  else
    # Unix/Linux/macOS Mise
    curl -k -sS https://mise.run | sh
  fi
fi

# Clean up curlrc so the system stays secure for daily use
rm -f ~/.curlrc

# --- Inject Mise into the current PATH so we can run it immediately ---
export PATH="$HOME/.local/bin:$HOME/.local/share/mise/bin:$HOME/.local/share/mise/shims:$PATH"

# --- Execute Provisioning ---
if _has mise; then
  echo "🚀 Reading ~/.config/mise/config.toml and provisioning tools..."

  # 👇 THIS IS THE MAGIC LINE 👇
  # Treat WSL identical to Linux for CLI tools
  if [ "$ENV_TYPE" = "wsl" ]; then
    export MISE_ENV="linux"
  else
    export MISE_ENV="$ENV_TYPE"
  fi

  # Run the installation
  mise install -y

  # Ensure shims (executables) are generated and linked
  mise reshim
else
  echo "❌ Failed to install or locate Mise. Core CLI tools may be missing."
fi

echo "========================================"
echo "✅ Setup complete! Restart your terminal or run 'source ~/.profile && source ~/.bashrc'."
echo "========================================"
